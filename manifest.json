{
  "manifest_version": 3,
  "name": "MonarchMoney Links",
  "version": "v2.0",
  "description": "Makes URLs in Monarch Money transaction Notes clickable by injecting a Links section.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://app.monarch.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ]
}