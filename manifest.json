{
  "manifest_version": 3,
  "name": "MonarchMoney Plus",
  "version": "2.0",
  "description": "Clickable URLs in transaction notes and automatic dashboard date-range selection for Monarch Money.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://app.monarch.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ]
}